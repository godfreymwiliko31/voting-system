# Copy to .env or set these in your host (Railway, Render, VPS, etc.)

# Required for production:
NODE_ENV=production
SESSION_SECRET=replace-with-long-random-secret-at-least-24-chars

# Optional:
PORT=3000

# SQLite file path (relative to process cwd, or absolute)
# VOTING_DB_PATH=./voting.db

# Trust X-Forwarded-* from reverse proxy (default 1). Increase if needed behind multiple proxies.
# TRUST_PROXY_HOPS=1
