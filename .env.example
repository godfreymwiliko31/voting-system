# Copy to .env or set these in your host (cPanel/PM2/VPS, etc.)

# Optional (default 3000)
PORT=3000

# SQLite database path (MUST be on persistent storage)
# Default: ./data/voting.db
# DB_PATH=/home/USER/app/data/voting.db

# Recommended for production
# NODE_ENV=production
# SESSION_SECRET=replace-with-long-random-secret-at-least-24-chars

# Optional: seed the very first admin user (runs only if no admin exists yet)
# ADMIN_USERNAME=admin
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=replace-with-strong-password
